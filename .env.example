# 服务配置
PORT=8098
NODE_ENV=production

# 前端地址
FRONTEND_URL=http://localhost:3000

# Puppeteer配置
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=60000
# Chrome可执行文件路径(如果系统已安装Chrome,指定路径)
# 常见路径: /usr/bin/google-chrome, /usr/bin/chromium, /usr/bin/chromium-browser
CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome

# 日志配置
LOG_LEVEL=info
